# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Comma-separated Telegram user IDs allowed to use the bot/Mini App
ADMIN_IDS=111111111,222222222

# Browser (username/password) login accounts. Generate each line with:
#   python -m app.passwords <username>
# then paste the printed "user:pbkdf2_sha256$..." here. Comma-separate multiple.
# Leave empty to disable browser login (Telegram-only access).
ADMIN_CREDENTIALS=

# Telegram channels used by bulk-send buttons.
BOT_KARGOLARGA_TARQATISH_CHANNEL_ID=
BOT_TOP_TYPE_CHANNEL_ID=
BOT_TOPDAN_CHIQGAN_CHANNEL_ID=
BOT_BIZDA_QOLADIGAN_CHANNEL_ID=
BOT_BIZDAN_CHIQGAN_CHANNEL_ID=

# Public HTTPS url where the Mini App is served (required by Telegram).
# For local dev use a tunnel, e.g. cloudflared: https://xxxx.trycloudflare.com
WEBAPP_URL=https://your-domain.example

# Server bind. Keep 127.0.0.1 when fronted by a local tunnel (cloudflared) so the
# port is not reachable on the LAN. Use 0.0.0.0 only if you must expose it.
HOST=127.0.0.1
PORT=8080

# Extra (non-loopback) reverse-proxy IPs whose X-Forwarded-For / CF-Connecting-IP
# to honor for per-client rate limiting. Loopback peers (127.0.0.1/::1) are always
# trusted, so a local cloudflared tunnel needs nothing here. Set this only when a
# proxy runs on another host.
TRUSTED_PROXIES=

# Reject initData older than N seconds (replay protection). 0 = disabled.
INITDATA_MAX_AGE=86400

# Browser session lifetime in seconds (default 12h). Stateless tokens can't be
# revoked individually; remove a user's ADMIN_CREDENTIALS line to kill their sessions.
SESSION_TTL=43200
